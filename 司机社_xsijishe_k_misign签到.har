[
  {
    "comment": "进入每日签到页，提取 Discuz formhash。Cookie 由 QD 运行时变量 {{cookie}} 提供。",
    "request": {
      "method": "GET",
      "url": "https://xsijishe.com/k_misign-sign.html",
      "headers": [
        {
          "name": "Accept",
          "value": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8"
        },
        {
          "name": "Accept-Language",
          "value": "zh-CN,zh;q=0.9,en;q=0.8"
        },
        {
          "name": "Cache-Control",
          "value": "no-cache"
        },
        {
          "name": "Pragma",
          "value": "no-cache"
        },
        {
          "name": "Referer",
          "value": "https://xsijishe.com/"
        },
        {
          "name": "User-Agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36"
        },
        {
          "name": "Cookie",
          "value": "{{cookie}}"
        }
      ],
      "cookies": []
    },
    "rule": {
      "success_asserts": [
        {
          "re": "200",
          "from": "status"
        },
        {
          "re": "每日签到|k_misign",
          "from": "content"
        }
      ],
      "failed_asserts": [
        {
          "re": "请先登录|立即登录|member.php\\?mod=logging",
          "from": "content"
        }
      ],
      "extract_variables": [
        {
          "name": "formhash",
          "re": "formhash=([a-f0-9]{8})",
          "from": "content"
        }
      ]
    }
  },
  {
    "comment": "调用 k_misign 签到接口。未签到会完成签到，已签到通常返回已签提示。",
    "request": {
      "method": "GET",
      "url": "https://xsijishe.com/plugin.php?id=k_misign:sign&operation=qiandao&formhash={{formhash}}&format=empty",
      "headers": [
        {
          "name": "Accept",
          "value": "text/html, */*; q=0.01"
        },
        {
          "name": "Accept-Language",
          "value": "zh-CN,zh;q=0.9,en;q=0.8"
        },
        {
          "name": "Cache-Control",
          "value": "no-cache"
        },
        {
          "name": "Pragma",
          "value": "no-cache"
        },
        {
          "name": "Referer",
          "value": "https://xsijishe.com/k_misign-sign.html"
        },
        {
          "name": "X-Requested-With",
          "value": "XMLHttpRequest"
        },
        {
          "name": "User-Agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36"
        },
        {
          "name": "Cookie",
          "value": "{{cookie}}"
        }
      ],
      "cookies": []
    },
    "rule": {
      "success_asserts": [
        {
          "from": "status",
          "re": "200"
        },
        {
          "from": "content",
          "re": "签到|已签|成功|奖励|车票|k_misign"
        }
      ],
      "failed_asserts": [
        {
          "from": "content",
          "re": "请先登录|立即登录|登录|member\\.php\\?mod=logging|<form[^>]+login|username|password"
        },
        {
          "from": "status",
          "re": "302|301"
        }
      ],
      "extract_variables": [
        {
          "name": "sign_response",
          "re": "([\\s\\S]{0,300})",
          "from": "content"
        }
      ]
    }
  }
]
